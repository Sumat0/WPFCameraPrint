<Window x:Class="WpfCamera.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WpfCamera" 
				xmlns:xamlhost="clr-namespace:Microsoft.Toolkit.Wpf.UI.XamlHost;assembly=Microsoft.Toolkit.Wpf.UI.XamlHost"
				mc:Ignorable="d"
        Title="WPF camera">

	<Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <xamlhost:WindowsXamlHost x:Name="XamlHost" Grid.Row="0" Margin="0 0 0 40" />
        <StackPanel Grid.Row="1">
            <TextBox x:Name="txtName" Width="200" Height="30" Margin="10" />
            <TextBox x:Name="txtCompany" Width="200" Height="30" Margin="10" />
            <Button Content="Attach Photo?" Margin="10" Click="AttachPhoto_Click" />
            <Button x:Name="btnPhoto" Content="Photo" Margin="10" Click="Photo_Click" IsEnabled="False"/>
            <Button Content="Print" Margin="10" Click="btnPrint_Click" />
        </StackPanel>
	</Grid>
</Window>
